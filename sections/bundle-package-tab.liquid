<style>
.bundle-package-tab-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
}

  .bundle-package-tab-{{ section.id }} .bundle-package-tab__wrapper{
  background-color: {{ section.settings.background_color }};
}

@media (max-width: 990px) {
  .bundle-package-tab-{{ section.id }} {
  padding-top: {{ section.settings.mobile_padding_top }}px;
  padding-bottom: {{ section.settings.mobile_padding_bottom }}px;
  }
}

.bundle-package-tab__wrapper {
  padding: 48px 32px;
  border-radius: 20px;
}

.bundle-package-tab__panel {
  display: none;
  gap: 48px;
  align-items: center;
}

.bundle-package-tab__panel.bundle-tab-active {
  display: flex;
}

.bundle-package-tab__swiper-thumb .swiper-slide {
  width: 80px !important;
  height: 80px !important;
  opacity: 0.65;
}

.bundle-package-tab__swiper-thumb .swiper-slide-thumb-active {
  opacity: 1;
}

.bundle-package-tab__media {
  max-width: 509px;
  width: 100%;
}

.bundle-package-tab__swiper-thumb {
  margin-top: 16px;
}

.bundle-package-tab__slide {
  cursor: pointer;
}

.bundle-package-tab__slide img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: 14px;
  aspect-ratio: 1 / 1;
}

.bundle-package-tab__slide-thumb {
  cursor: pointer;
}

.bundle-package-tab__slide-thumb img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: 8px;
}

.bundle-package-tab__info {
  max-width: 755px;
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 56px;
}

.bundle-package-tab__subheading p {
  color: #6A6A6A;
  font-weight: 600;
  font-size: 16px;
  line-height: 21.6px;
  letter-spacing: -2%;
  margin: 0;
}

.bundle-package-tab__tabs {
  display: flex;
  align-items: center;
  background-color: #fff;
  border-radius: 12px;
  padding: 2px;
}

button.bundle-package-tab__tab-btn {
  background-color: #fff;
  padding: 11px 16px;
  border-radius: 8px;
  border: none;
  color: rgba(106, 106, 106, 0.5);
  font-weight: 600;
  font-size: 16px;
  line-height: 135%;
  letter-spacing: -2%;
  text-align: center;
  width: 50%;
  cursor: pointer;
  transition: background-color 0.3s ease, color 0.3s ease;
}


button.bundle-package-tab__tab-btn:hover {
  background-color: #6774A5;
  color: #fff;
}

button.bundle-package-tab__tab-btn.bundle-tab-btn-active {
  background-color: #6774A5;
  color: #fff;
}

.bundle-package-tab__heading {
  padding: 24px 0 16px;
}

.bundle-package-tab__heading h2 {
  color: #232323;
  font-weight: 600;
  font-size: 36px;
  line-height: normal;
  letter-spacing: -2%;
  text-transform: capitalize;
  margin: 0;
}

.bundle-package-tab__description p {
  color: #6A6A6A;
  font-weight: 500;
  font-size: 18px;
  line-height: 20.8px;
  letter-spacing: -1%;
  margin: 0;
}

.bundle-package-tab__description p strong {
  color: #232323;
  font-weight: 600;
}

.bundle-package-tab__text-wrap {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.bundle-package-tab__text {
  display: flex;
  gap: 8px;
  align-items: center;
}

.bundle-package-tab__text svg {
  display: flex;
  width: 18px;
  height: 18px;
  stroke: unset;
}

.bundle-package-tab__text p {
  color: #232323;
  font-weight: 400;
  font-size: 18px;
  line-height: 20.8px;
  letter-spacing: -1%;
  margin: 0;
}

.bundle-package-tab__text:not(:last-child) {
  border-bottom: 1px solid #2323231A;
  padding-bottom: 12px;
}


.bundle-package-tab__btn-wrap .bundle-package-tab__btn {
  display: inline-block;
  background-color: #6774A5;
  padding: 17px 24px;
  border-radius: 8px;
  color: #FFFFFF;
  font-weight: 600;
  font-size: 14px;
  line-height: normal;
  letter-spacing: 0;
  margin: 0;
  text-transform: uppercase;
  text-decoration: none;
  max-width: 133px;
  width: 100%;
  transition:0.3s;
}

  .bundle-package-tab__btn-wrap .bundle-package-tab__btn:hover {
    background-color: #000;
    color: #FFFFFF;
  }

.bundle-package-tab__media.desktop-hide {
  display: none;
}


@media only screen and (max-width:990px) {

  .bundle-package-tab__wrapper {
    padding: 24px 16px 32px;
    border-radius: 12px;
  }

  .bundle-package-tab__panel {
    flex-direction: column;
  }

  .bundle-package-tab__media {
    max-width: 100%;
  }

  .bundle-package-tab__slide img {
    border-radius: 12px;
  }

  .bundle-package-tab__swiper-thumb {
    display: none !important;
  }

  .bundle-package-tab__info {
    max-width: 100%;
    gap: 48px;
  }

  .bundle-package-tab__tabs {
    border-radius: 10px;
  }

  button.bundle-package-tab__tab-btn {
    padding: 8px 16px;
    border-radius: 6px;
    font-size: 12px;
    line-height: 15.6px;
  }

  .bundle-package-tab__heading h2 {
    font-size: 24px;
  }

  .bundle-package-tab__description p {
    font-size: 14px;
    line-height: 20px;
  }

  .bundle-package-tab__text p {
    font-size: 14px;
    line-height: 18.2px;
  }

  .bundle-package-tab__btn-wrap {
    text-align: center;
  }

  .bundle-package-tab__btn-wrap .bundle-package-tab__btn {
    padding: 12px 24px;
  }

  .bundle-package-tab__media.mobile-hide {
    display: none;
  }

  .bundle-package-tab__media.desktop-hide {
    display: block;
  }

}
</style>

