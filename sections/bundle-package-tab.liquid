<div class="bundle-package-tab bundle-package-tab-{{ section.id }}">
  <div class="container">
    <div class="bundle-package-tab__wrapper">
      {% if section.blocks.size > 0 %}
        {% for block in section.blocks %}
          {% assign product = block.settings.product %}
          {% assign btn_url = block.settings.button_url | default: product.url %}
          <div
            id="bpt-panel-{{ section.id }}-{{ forloop.index }}"
            class="bundle-package-tab__panel"
            data-tab-index="{{ forloop.index }}"
            role="tabpanel"
          >
            <div class="bundle-package-tab__media mobile-hide">
              {% render 'bpt-product-media', product: product, section_id: section.id, block_index: forloop.index %}
            </div>

            <div class="bundle-package-tab__info">
              {% if section.settings.subheading != blank %}
                <div class="bundle-package-tab__subheading">
                  <p>{{ section.settings.subheading }}</p>
                </div>
              {% endif %}
              <div class="bundle-package-tab__top">
                <div class="bundle-package-tab__tabs" role="tablist">
                  {% for tab_block in section.blocks %}
                    {% assign tab_name = tab_block.settings['tab-name'] | default: tab_block.settings.heading %}
                    <button
                      class="bundle-package-tab__tab-btn{% if forloop.index == forloop.parentloop.index %} bundle-tab-btn-active{% endif %}"
                      data-tab-target="bpt-panel-{{ section.id }}-{{ forloop.index }}"
                      role="tab"
                      {{ tab_block.shopify_attributes }}
                    >
                      {{ tab_name }}
                    </button>
                  {% endfor %}
                </div>
                {% if block.settings.heading != blank %}
                  <div class="bundle-package-tab__heading">
                    <h2>{{ block.settings.heading }}</h2>
                  </div>
                {% endif %}

                {% if block.settings.description != blank %}
                  <div class="bundle-package-tab__description">
                    {{ block.settings.description }}
                  </div>
                {% endif %}
              </div>
              <div class="bundle-package-tab__media desktop-hide">
                {% render 'bpt-product-media', product: product, section_id: section.id, block_index: forloop.index %}
              </div>
              <div class="bundle-package-tab__text-wrap">
                {% for i in (1..6) %}
                  {% assign text_key = 'text_' | append: i %}
                  {% if block.settings[text_key] != blank %}
                    <div class="bundle-package-tab__text">
                      <span>{{ text-icon }}</span>
                      <p>{{ block.settings[text_key] }}</p>
                    </div>
                  {% endif %}
                {% endfor %}
              </div>
              {% if block.settings.button_label != blank %}
                <div class="bundle-package-tab__btn-wrap">
                  <a
                    href="{{ btn_url }}"
                    class="bundle-package-tab__btn"
                  >
                    {{ block.settings.button_label }}
                  </a>
                </div>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    var section = document.querySelector('.bundle-package-tab-{{ section.id }}');
    if (!section) return;

    {% for block in section.blocks %}
      (function () {
        var thumbEl = document.getElementById('bpt-thumb-{{ section.id }}-{{ forloop.index }}');
        var mainEl  = document.getElementById('bpt-main-{{ section.id }}-{{ forloop.index }}');
        if (!thumbEl || !mainEl) return;

        var thumbSwiper = new Swiper(thumbEl, {
          slidesPerView: 'auto',
          spaceBetween: 8,
          watchSlidesProgress: true,
          freeMode: true,
          slideToClickedSlide: true,
          loop: true,
        });

        var mainSwiper = new Swiper(mainEl, {
          slidesPerView: 1,
          spaceBetween: 0,
          loop: true,
          thumbs: {
            swiper: thumbSwiper,
          },
          on: {
            slideChange: function () {
              thumbSwiper.slideTo(this.realIndex);
            },
          },
        });
      })();
    {% endfor %}

    var tabPanels = section.querySelectorAll('.bundle-package-tab__panel');
    if (tabPanels.length > 0) {
      tabPanels[0].classList.add('bundle-tab-active');
    }

    section.addEventListener('click', function (e) {
      var btn = e.target.closest('.bundle-package-tab__tab-btn');
      if (!btn || !section.contains(btn)) return;

      var targetId = btn.getAttribute('data-tab-target');
      if (!targetId) return;

      var allPanels = section.querySelectorAll('.bundle-package-tab__panel');
      allPanels.forEach(function (p) { p.classList.remove('bundle-tab-active'); });

      var targetPanel = document.getElementById(targetId);
      if (targetPanel) targetPanel.classList.add('bundle-tab-active');

      var activeTabs = targetPanel.querySelectorAll('.bundle-package-tab__tab-btn');
      var allTabs = section.querySelectorAll('.bundle-package-tab__tab-btn');
      allTabs.forEach(function (t) { t.classList.remove('bundle-tab-btn-active'); });
      activeTabs.forEach(function (t) {
        if (t.getAttribute('data-tab-target') === targetId) {
          t.classList.add('bundle-tab-btn-active');
        }
      });
    });
  });
</script>

{% schema %}
{
  "name": "Bundle Package Tab",
  "tag": "section",
  "class": "section-bundle-package-tab",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Sub Heading",
      "default": "CHECK OUT THE BUNDLE PACKAGE"
    },
    {
      "type": "header",
      "content": "Background Color"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Padding Top (Desktop)",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Padding Bottom (Desktop)",
      "default": 40
    },
    {
      "type": "range",
      "id": "mobile_padding_top",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Padding Top (Mobile)",
      "default": 20
    },
    {
      "type": "range",
      "id": "mobile_padding_bottom",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Padding Bottom (Mobile)",
      "default": 20
    }
  ],
  "blocks": [
    {
      "type": "tab",
      "name": "Tab",
      "limit": 2,
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Select a Product"
        },
        {
          "type": "text",
          "id": "tab-name",
          "label": "Tab Name"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description"
        },
        {
          "type": "text",
          "id": "text_1",
          "label": "Text (1)"
        },
        {
          "type": "text",
          "id": "text_2",
          "label": "Text (2)"
        },
        {
          "type": "text",
          "id": "text_3",
          "label": "Text (3)"
        },
        {
          "type": "text",
          "id": "text_4",
          "label": "Text (4)"
        },
        {
          "type": "text",
          "id": "text_5",
          "label": "Text (5)"
        },
        {
          "type": "text",
          "id": "text_6",
          "label": "Text (6)"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button Label"
        },
        {
          "type": "url",
          "id": "button_url",
          "label": "Button URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Bundle Package Tab"
    }
  ]
}
{% endschema %}
