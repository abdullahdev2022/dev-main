  align-items: center;
  gap: 8px;
  padding-bottom:24px;
      }

        .infoDrawer_tab_item span {
      border-radius: 16px;
      border: 1px solid rgba(0, 0, 0, 0.10);
      background: rgba(0, 0, 0, 0.05);
      padding: 8px 16px;
      display: inline-block;
      color: #272727;
      font-size: 10px;
      font-style: normal;
      font-weight: 400;
      line-height: 11px;
      text-transform: capitalize;
    }

    .infoDrawer_tab_item.active span {
      border-radius: 16px;
      border: 1px solid #000;
      background: #000;
      color: #E2C888;
    }
</style>

