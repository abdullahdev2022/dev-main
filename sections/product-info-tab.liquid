<script>
  (function () {
    const section = document.querySelector('.product-info-tab-{{ section.id }}');
    if (!section) return;

    const tabItems = section.querySelectorAll('[data-tab-index]');
    const contentWrappers = section.querySelectorAll('[data-tab-content]');

    if (!tabItems.length || !contentWrappers.length) return;

    section.querySelectorAll('.product-info-tab__video').forEach(function (videoContainer) {
      var video = videoContainer.querySelector('video');
      var muteBtn = videoContainer.querySelector('.product-info-tab_audio_btn');
      if (!video || !muteBtn) return;

      if (video.muted) {
        muteBtn.classList.add('is-muted');
      }
    });

    function stopAllVideos(exceptContainer) {
      section.querySelectorAll('.product-info-tab__video').forEach(function (container) {
        if (container === exceptContainer) return;
        var video = container.querySelector('video');
        var playBtn = container.querySelector('.product-info-tab_play_btn');
        var thumbnail = container.querySelector('.product-info-tab__image-thumbnail');

        if (video && !video.paused) {
          video.pause();
          if (playBtn) playBtn.classList.remove('is-playing');
          if (thumbnail) thumbnail.classList.remove('is-hidden');
        }
      });
    }

    function activateTab(index) {
      tabItems.forEach(function (tab) {
        tab.classList.remove('is-active');
      });

      contentWrappers.forEach(function (content) {
        content.classList.remove('is-active');

        var video = content.querySelector('video');
        var playBtn = content.querySelector('.product-info-tab_play_btn');
        var thumbnail = content.querySelector('.product-info-tab__image-thumbnail');

        if (video && !video.paused) {
          video.pause();
          if (playBtn) playBtn.classList.remove('is-playing');
          if (thumbnail) thumbnail.classList.remove('is-hidden');
        }
      });

      var activeTab = section.querySelector('[data-tab-index="' + index + '"]');
      var activeContent = section.querySelector('[data-tab-content="' + index + '"]');

      if (activeTab) {
        activeTab.classList.add('is-active');
        activeTab.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'start' });
      }

      if (activeContent) {
        activeContent.classList.add('is-active');
      }
    }

    tabItems.forEach(function (tab, index) {
      tab.addEventListener('click', function () {
        activateTab(index);
      });

      tab.addEventListener('keydown', function (e) {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          activateTab(index);
        }
      });
    });

    section.querySelectorAll('.product-info-tab_play_btn').forEach(function (button) {
      var videoContainer = button.closest('.product-info-tab__video');
      if (!videoContainer) return;

      var video = videoContainer.querySelector('video');
      var thumbnail = videoContainer.querySelector('.product-info-tab__image-thumbnail');

      if (!video) return;

      button.addEventListener('click', function () {
        if (video.paused) {
          stopAllVideos(videoContainer);

          video.play().catch(function () {});

          button.classList.add('is-playing');
          if (thumbnail) thumbnail.classList.add('is-hidden');
        } else {
          video.pause();
          button.classList.remove('is-playing');
          if (thumbnail) thumbnail.classList.remove('is-hidden');
        }
      });

      video.addEventListener('ended', function () {
        button.classList.remove('is-playing');
        if (thumbnail) thumbnail.classList.remove('is-hidden');
      });
    });

    section.querySelectorAll('.product-info-tab_audio_btn').forEach(function (button) {
      var videoContainer = button.closest('.product-info-tab__video');
      if (!videoContainer) return;

      var video = videoContainer.querySelector('video');
      if (!video) return;

      button.addEventListener('click', function () {
        video.muted = !video.muted;
        button.classList.toggle('is-muted', video.muted);
      });
    });
  })();
</script>

