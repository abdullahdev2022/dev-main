<link
  rel="stylesheet"
  href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css"
>

{% style %}
  .events-main--{{ section.id }}{
      padding-top:{{ section.settings.top_padding_desktop }}px;
      padding-bottom:{{ section.settings.bottom_padding_desktop }}px;
      overflow:hidden;
  }
  @media only screen and (max-width:768px){
     .events-main--{{ section.id }}{
          padding-top:{{ section.settings.top_padding_mobile }}px;
          padding-bottom:{{ section.settings.bottom_padding_mobile }}px;
      }
  }
{% endstyle %}
{% style %}
     .events-inner{
         display:flex;
         flex-direction:column;
         gap:41px;
     }
     .events-header{
         display:flex;
         flex-direction:column;
     }
     .events-card__text-content{
         width:100%;
     }
     .events-card__block-wrap{
         display:flex;
         gap:14px;
     }
     .events-calender{
         max-width:25%;
         width:100%;
         display:flex;
         flex-direction:column;
         gap:24px;
     }
     .events-calender__bottom{
         padding:24px;
         border-radius: 12px;
         border: 1px solid #E6E1D8;
         background: #FFF;
     }
     .events-calender__bottom-heading h2{
         color: #0F0F0F;
         font-family: var(--font-satoshi);
         font-size: 20px;
         font-style: normal;
         font-weight: 700;
         line-height: normal;
         letter-spacing: -0.4px;
         margin:0;
         text-transform:none;
     }
     .events-calender__bottom-subheading{
         padding-top:5px;
     }
     .events-calender__bottom-subheading p{
         color: #9E9E9E;
         font-family: var(--font-satoshi);
         font-size: 9.5px;
         font-style: normal;
         font-weight: 500;
         line-height: normal;
         letter-spacing: 1.4px;
          margin:0;
         text-transform:none;
     }
     .events-card__date p{
         color:#6B6B6B;
         text-align: center;
         font-family:  var(--font-satoshi);
         font-size: 12px;
         font-style: normal;
         font-weight: 700;
         line-height: 20.4px;
         letter-spacing: 1.8px;
         text-transform: uppercase;
         margin:0;
     }
     .events-card__date h2{
         color: #0F0F0F;
         font-family: var(--font-inter);
         font-size: 38px;
         font-style: normal;
         font-weight: 700;
         line-height: 50.4px;
         letter-spacing: -2.1px;
         text-transform:none;
         margin:0;
     }
     .events-card__time{
         display: flex;
         align-items: center;
         justify-content: space-between;
     }
     .events-header__heading h2{
         color: #0F0F0F;
         font-family: var(--font-satoshi);
         font-size: 38px;
         font-style: normal;
         font-weight: 700;
         line-height: 50.4px;
         letter-spacing: -2.1px;
         text-transform:none;
         margin:0;
     }
     .events-header__subheading p{
         color: rgba(0, 0, 0, 0.60);
         font-family: var(--font-satoshi);
         font-size: 18px;
         font-style: normal;
         font-weight: 500;
         line-height: 27.2px;
         text-transform:none;
         margin:0;
     }
     .events-header__link a{
         color: #666;
         font-family: var(--font-satoshi);
         font-size: 20px;
         font-style: normal;
         font-weight: 500;
         line-height: normal;
         display: inline-flex;
         text-transform: none;
         margin: 0;
         align-items: center;
     }
     .event-tabs{
         padding-bottom:6px;
         gap:8px;
     }
     .event-tabs span.active{
         background:#4A4A4A;
         border:1px solid #4A4A4A;
         color:#fff;
     }
     .event-tabs span{
         display:inline-block;
         color: #4A4A4A;
         font-family: var(--font-satoshi);
         font-size: 12px;
         font-style: normal;
         font-weight: 700;
         line-height: normal;
         letter-spacing: 0.5px;
         text-transform:none;
         padding:9px 16px;
         border-radius:20px;
         cursor:pointer;
         border:1px solid #D8D2C6;
         margin:0;
     }
    .event-tabs,.events-card__items,.events-header__heading{
         display:flex;
     }
     .events-header__heading{
         align-items:center;
         gap:21px;
     }
     .events-header{
         gap:11px;
     }
     .events-card__items{
         gap:39px;
         align-items:center;
     }
     .events-upcoming__text{
         padding-bottom:9px;
     }
     .events-upcoming__text p{
         color: #666;
         font-family: var(--font-satoshi);
         font-size: 12px;
         font-style: normal;
         font-weight: 500;
         line-height: normal;
         letter-spacing: 1.5px;
         margin:0;
         text-transform:none;
     }
     .events-card{
         padding:0 48px;
         border-radius: 10px;
         background: rgba(196, 168, 130, 0.16);
     }
     .events-card__wrap{
         display:flex;
         max-width:75%;
         width:100%;
         flex-direction:column;
         gap:12px;
     }
     .events-card__subheading h3{
         color: #666;
         font-family: var(--font-inter);
         font-size: 10px;
         font-style: normal;
         font-weight: 500;
         line-height: normal;
         letter-spacing: 1.2px;
         margin:0;
     }
     .events-card__heading{
         padding:8px 0;
     }
     .events-card__heading h2{
         color:#0F0F0F;
         font-family:var(--font-inter);
         font-size: 20px;
         font-style: normal;
         font-weight:700;
         line-height:50.4px;
         letter-spacing: -1px;
         text-transform: capitalize;
         margin:0;
     }
     .events-card__description{
         padding-bottom:26px;
     }
     .events-card__description p{
         color: rgba(0, 0, 0, 0.60);
         font-family: var(--font-inter);
         font-size: 16px;
         font-style: normal;
         font-weight:500;
         line-height:27.2px;
         margin:0;
         text-transform:none;
     }
     .events-card__time p{
         color: rgba(0, 0, 0, 0.60);
         font-family: var(--font-inter);
         font-size: 14px;
         font-style: normal;
         font-weight:500;
         line-height: 27.2px;
         margin:0;
         display:flex;
         gap:12px;
         align-items:center;
     }
      .events-card__time p svg{
         width:22px;
         height:22px;
      }
      .events-card__btn{
         max-width:215px;
         width:100%;
      }
      .events-card__btn Button{
          color: #000;
          padding:0;
          width:100%;
          text-align:left;
          font-family: var(--font-inter);
          font-size: 14px;
          font-style: normal;
          font-weight: 500;
          line-height: 26.141px;
          display:block;
          border-bottom: 1px solid #000;
          letter-spacing: -0.647px;
          text-transform: capitalize;
          position:relative;
          padding-bottom:8px;
          margin:0;
     }
     .events-calender__bottom-hours{
         display:flex;
         justify-content:space-between;
         align-items:center;
     }
     .events-card__btn button:after{
         content: "";
         position: absolute;
         right: 0;
         background-image: url(https://cdn.shopify.com/s/files/1/0050/5393/9800/files/balck-arrow.svg?v=1775671445);
         width: 100%;
         height: 100%;
         background-repeat: no-repeat;
         background-position: right top;
     }
     .events-card__image{
         max-width: 175px;
         aspect-ratio: 1 / 1.45;
     }
     .events-card__image img{
         width:100%;
         height:100%;
         object-fit:cover;
     }
     .events-calender__bottom-text p{
         color: #6B6B6B;
         font-family: var(--font-satoshi);
         font-size: 11px;
         font-style: normal;
         font-weight: 500;
         line-height: normal;
         margin:0;
         text-transform:none;
         display:flex;
         gap:8px;
         align-items:center;
         letter-spacing: -0.1px;
     }
     .events-calender__bottom-hours p{
         color: #0F0F0F;
         font-family: var(--font-satoshi);
         font-size: 13.5px;
         font-style: normal;
         font-weight: 500;
         line-height: normal;
         letter-spacing: -0.2px;
         margin:0;
         text-transform:none;
     }
     .events-calender__bottom hr{
         margin:0;
     }
     .events-calender__bottom-hours span{
         display:block;
         color: #6B6B6B;
         font-family:var(--font-satoshi);
         font-size: 13.5px;
         font-style: normal;
         font-weight: 400;
         line-height: normal;
         letter-spacing: -0.2px;
         margin:0;
         text-transform:none;
     }
     .events-calender__bottom{
         display:flex;
         flex-direction:column;
         gap:18px;
     }
     .events-main .mobile-hide{
         display:flex;
     }
     .events-main .desktop-hide{
         display:none;
     }

     @media only screen and (max-width:768px){
         .events-card__block-wrap{
             flex-direction:column-reverse;
         }
         .events-calender,.events-card__wrap{
             max-width:100%;
         }
         .event-tabs{
             flex-wrap:nowrap;
             white-space:nowrap;
             overflow:hidden;
             overflow-X:auto;
             scrollbar-width:none;
         }
         .events-card__items{
             flex-direction:column;
         }
         .events-card{
             overflow:hidden;
             padding:0;
         }
         .events-card__image{
             all:unset;
             order:1;
             width:100%;
         }
         .events-card__time{
             flex-direction:column;
             align-items:unset;
         }
         .events-card__date{
             order:2;
         }
         .events-card__text-content{
             order:3;
             padding:16px;
         }
         .events-main .mobile-hide{
         display:none;
     }
     .events-main .desktop-hide{
         display:flex;
     }
     }

  /* drawer */

    .events-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.45);
  z-index: 98;
  opacity: 0;
  visibility: hidden;
  transition: 0.3s ease;
  cursor: pointer;
  }

  .events-overlay.active {
  opacity: 1;
  visibility: visible;
  }

{% endstyle %}
{% liquid
  assign header_heading = section.settings.heading
  assign header_subheading = section.settings.subheading
  assign header_link_txt = section.settings.link_txt
  assign header_link_url = section.settings.url
  assign tab_text = section.settings.tab_text | split: ','
  assign cal_heading = section.settings.cal_heading
  assign cal_subheading = section.settings.cal_subheading
  assign upcoming_event_heading = section.settings.upcoming_event_heading

  assign section_id = section.id
  assign show_filter = section.settings.show_filter
%}
