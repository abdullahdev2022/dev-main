<div class="events-main events-main--{{ section.id }}" data-section-type="events">
  <div class="page-width">
    <div class="events-inner">
      <div class="events-header">
        <div class="events-header__heading">
          {% if header_heading != blank %}
            <h2>{{ header_heading }}</h2>
          {% endif %}
          {% if header_link_txt != blank %}
            <div class="events-header__link">
              <a href="{{ header_link_url }}" arial-label="event-header-link">
                {{ header_link_txt }}
                {{ right_arrow }}
              </a>
            </div>
          {% endif %}
        </div>
        {% if header_subheading != blank %}
          <div class="events-header__subheading">
            <p>{{ header_subheading }}</p>
          </div>
        {% endif %}
      </div>
      <div class="events-content">
        <div class="events-card__block-wrap">
          <div class="events-calender">
            {% render 'events-calender', section: section, section_id: section_id, show_filter: show_filter %}
            <div class="events-calender__bottom">
              <div class="events-calender__bottom-heading">
                {% if cal_heading != blank %}
                  <h2>{{ cal_heading }}</h2>
                {% endif %}
                {% if cal_subheading != blank %}
                  <div class="events-calender__bottom-subheading">
                    <p>{{ cal_subheading }}</p>
                  </div>
                {% endif %}
              </div>

              <div class="events-calender__bottom-hours">
                <p>Monday – Friday</p>
                <span>10:00 – 6:00</span>
              </div>
              <hr style="display:block !impiortant;">
              <div class="events-calender__bottom-text">
                <p>
                  <svg xmlns="http://www.w3.org/2000/svg" width="6" height="6" viewBox="0 0 6 6" fill="none">
                    <circle cx="3" cy="3" r="3" fill="#D2B976"/>
                  </svg>
                  Evening appointments available on request
                </p>
              </div>
            </div>
          </div>
          <div class="events-card__wrap">
            {% if tab_text != blank %}
              <div class="event-tabs">
                {% for txt in tab_text %}
                  <span>{{ txt | strip }}</span>
                {% endfor %}
              </div>
            {% endif %}
            {% if upcoming_event_heading != blank %}
              <div class="events-upcoming__text">
                <p>{{ upcoming_event_heading }}</p>
              </div>
            {% endif %}
            {% for block in section.blocks %}
              {% liquid
                assign event_subheading = block.settings.event_subheading
                assign event_heading = block.settings.event_heading
                assign event_tag = block.settings.event_tag
                assign event_time = block.settings.event_time
                assign event_image = block.settings.event_image
                assign event_mob_image = block.settings.event_mob_image
                assign event_description = block.settings.event_description
                assign event_btn_text = block.settings.event_btn_text
                assign filter_event_date = block.settings.filter_event_date
                assign filter_event_end_date = block.settings.filter_event_end_date
                assign current_year = 'now' | date: '%Y'
                if filter_event_date.size == 10
                  assign stored_year = filter_event_date | date: '%Y'
                  if stored_year < current_year
                    assign display_year = current_year
                  else
                    assign display_year = stored_year
                  endif
                  assign full_date = filter_event_date
                elsif filter_event_date.size == 5
                  assign full_date = current_year | append: '-' | append: filter_event_date
                  assign display_year = current_year
                else
                  assign full_date = filter_event_date
                  assign display_year = filter_event_date | date: '%Y'
                endif

                assign event_month = full_date | date: '%b' | upcase
                assign event_day = full_date | date: '%-d'
                assign event_year = display_year
              %}
              <div
                class="events-card"
                data-tab="{{ event_tag | handleize }}"
                data-date="{{ filter_event_date }}"
                data-end-date="{{ filter_event_end_date }}"
                data-title="{{ event_heading | handleize }}"
                {{ block.shopify_attributes }}
              >
                <div class="events-card__items">
                  {% if filter_event_date != blank %}
                    <div class="events-card__date">
                      <p>{{ event_month }}</p>
                      <h2>{{ event_day }}</h2>
                      <p>{{ event_year }}</p>
                    </div>
                  {% endif %}
                  {% if event_image != blank %}
                    <div class="events-card__image">
                      {{
                        event_image
                        | image_url: width: 800
                        | image_tag: alt: event_image.alt, loading: 'lazy', class: 'mobile-hide'
                      }}
                      {% if event_mob_image != blank %}
                        {{
                          event_mob_image
                          | image_url: width: 800
                          | image_tag: alt: event_image.alt, loading: 'lazy', class: 'desktop-hide'
                        }}
                      {% endif %}
                    </div>
                  {% endif %}
                  <div class="events-card__text-content">
                    {% if event_subheading != blank %}
                      <div class="events-card__subheading">
                        <h3>{{ event_subheading }}</h3>
                      </div>
                    {% endif %}
                    {% if event_heading != blank %}
                      <div class="events-card__heading">
                        <h2>{{ event_heading }}</h2>
                      </div>
                    {% endif %}
                    {% if event_description != blank %}
                      <div class="events-card__description">
                        {{ event_description }}
                      </div>
                    {% endif %}
                    <div class="events-card__time">
                      {% if event_time != blank %}
                        <p>
                          {{ time_icon }}
                          {{ event_time }}
                        </p>
                      {% endif %}
                      {% if event_btn_text != blank %}
                        <div class="events-card__btn">
                          <button
                            type="button"
                            aria-label="event-link"
                            data-drawer-id="{{ block.id }}"
                          >
                            {{ event_btn_text }}
                          </button>
                        </div>
                      {% endif %}
                    </div>
                  </div>
                </div>
              </div>
            {% endfor %}
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
<div class="events-overlay"></div>
{% for block in section.blocks %}
  <div class="events-drawer" id="events-drawer-{{ block.id }}" data-drawer-id="{{ block.id }}">
    {% render 'events-drawer', block: block %}
  </div>
{% endfor %}


<script>
  document.addEventListener('DOMContentLoaded', function () {

    var sectionId = '{{ section_id }}';
    var mainSection = document.querySelector('.events-main--' + sectionId);
    if (!mainSection) return;

    var activeTab = null;
    var selectedDate = null;

    /* ---------- DRAWER (id-based: har event ka apna drawer) ---------- */
    var overlay = document.querySelector('.events-overlay');

    function closeAllDrawers() {
      document.querySelectorAll('.events-drawer').forEach(function (d) { d.classList.remove('active'); });
      if (overlay) overlay.classList.remove('active');
      mainSection.querySelectorAll('.events-card').forEach(function (c) { c.classList.remove('active'); });
      document.body.style.overflow = '';
    }

    function openDrawerById(id) {
      if (!id) return;
      closeAllDrawers();
      var drawer = document.getElementById('events-drawer-' + id);
      if (!drawer) return;
      drawer.classList.add('active');
      if (overlay) overlay.classList.add('active');
      document.body.style.overflow = 'hidden';

      var btn = mainSection.querySelector('.events-card__btn button[data-drawer-id="' + id + '"]');
      if (btn) { var card = btn.closest('.events-card'); if (card) card.classList.add('active'); }
    }

    // OPEN — button mainSection ke andar hai
    mainSection.addEventListener('click', function (e) {
      var drawerBtn = e.target.closest('.events-card__btn button');
      if (!drawerBtn) return;
      e.preventDefault();
      openDrawerById(drawerBtn.getAttribute('data-drawer-id'));
    });

    // CLOSE — drawers/overlay mainSection ke BAHAR hain, isliye document par
    document.addEventListener('click', function (e) {
      if (e.target.closest('.events-drawer__close')) closeAllDrawers();
      if (e.target.classList && e.target.classList.contains('events-overlay')) closeAllDrawers();
    });
    document.addEventListener('keydown', function (e) { if (e.key === 'Escape') closeAllDrawers(); });

    /* ---------- TABS ---------- */
    var tabs = mainSection.querySelectorAll('.event-tabs span');
    function normalize(str){ return (str||'').toLowerCase().trim().replace(/&/g,'and').replace(/\s+/g,'-'); }
    function pad(n){ return String(n).padStart(2,'0'); }
    function toISO(d){ return d.getFullYear()+'-'+pad(d.getMonth()+1)+'-'+pad(d.getDate()); }
    function toMD(str){ var s=(str||'').trim(); if(!s) return ''; return s.length>5 ? s.slice(5) : s; }

    if (tabs.length) {
      tabs[0].classList.add('active');
      var firstText = tabs[0].textContent.trim().toLowerCase();
      activeTab = firstText === 'all events' ? null : normalize(firstText);
    }
    tabs.forEach(function (tab) {
      tab.addEventListener('click', function () {
        tabs.forEach(t => t.classList.remove('active'));
        tab.classList.add('active');
        var text = tab.textContent.trim().toLowerCase();
        activeTab = text === 'all events' ? null : normalize(text);
        filterEvents();
      });
    });

    /* ---------- EVENT MAP (calendar dots) ---------- */
    var eventMap = {};
    {% for block in section.blocks %}
      {% assign d = block.settings.filter_event_date %}
      {% assign d_end = block.settings.filter_event_end_date %}
      {% assign title = block.settings.event_heading %}
      {% if d != blank and title != blank %}
        (function () {
          var rawStart = "{{ d }}".trim(), rawEnd = "{{ d_end }}".trim();
          var startMD = rawStart.length>5 ? rawStart.slice(5) : rawStart;
          var endMD   = rawEnd.length>5   ? rawEnd.slice(5)   : rawEnd;
          if (!eventMap[startMD]) eventMap[startMD] = [];
          eventMap[startMD].push({ startMD: startMD, endMD: endMD, title: "{{ title | strip_html | strip | handleize }}" });
        })();
      {% endif %}
    {% endfor %}

    function mdInt(md){ var p=(md||'').split('-'); return parseInt(p[0],10)*100+parseInt(p[1],10); }
    function cardMatchesDate(card, pickedISO){
      var pickedMD = toMD(pickedISO);
      var rawStart = (card.getAttribute('data-date')||'').trim();
      var rawEnd   = (card.getAttribute('data-end-date')||'').trim();
      if (!rawStart) return false;
      var startMD = rawStart.length>5 ? rawStart.slice(5) : rawStart;
      var endMD   = rawEnd.length>5   ? rawEnd.slice(5)   : rawEnd;
      if (!endMD) return pickedMD === startMD;
      var s=mdInt(startMD), e=mdInt(endMD), p=mdInt(pickedMD);
      if (s<=e) return p>=s && p<=e;
      return p>=s || p<=e;
    }
    function hasEventsOnDate(pickedISO){
      var cards = mainSection.querySelectorAll('.events-card');
      for (var i=0;i<cards.length;i++){ if (cardMatchesDate(cards[i],pickedISO)) return true; }
      return false;
    }
    function filterEvents(){
      mainSection.querySelectorAll('.events-card').forEach(function (card) {
        var tabMatch  = !activeTab || normalize(card.getAttribute('data-tab')) === activeTab;
        var dateMatch = !selectedDate || cardMatchesDate(card, selectedDate);
        card.style.display = (tabMatch && dateMatch) ? '' : 'none';
      });
    }
    function applySmartDefault(){
      var todayISO = toISO(new Date());
      selectedDate = hasEventsOnDate(todayISO) ? todayISO : null;
      filterEvents();
    }

    /* ---------- FLATPICKR ---------- */
    var calWrap = document.querySelector('#ec-flatpickr-' + sectionId);
    function addDots(){
      if (!calWrap || !Object.keys(eventMap).length) return;
      document.querySelectorAll('.ec-event-dot').forEach(function (d) { d.remove(); });
      document.querySelectorAll('.flatpickr-day').forEach(function (dayEl) {
        var label = dayEl.getAttribute('aria-label'); if (!label) return;
        var parsed = new Date(label);
        if (isNaN(parsed.getTime())) parsed = new Date(Date.parse(label));
        if (isNaN(parsed.getTime())) return;
        var md = pad(parsed.getMonth()+1)+'-'+pad(parsed.getDate());
        if (eventMap[md] && !dayEl.querySelector('.ec-event-dot')) {
          var dot = document.createElement('span'); dot.className='ec-event-dot'; dayEl.appendChild(dot);
        }
      });
    }
    function setupFlatpickr(){
      if (!calWrap || typeof flatpickr === 'undefined') return;
      flatpickr(calWrap, {
        inline: true, disableMobile: true,
        onReady: function (sd, ds, instance) {
          var today = new Date(), todayISO = toISO(today);
          instance.setDate(today, true);
          selectedDate = hasEventsOnDate(todayISO) ? todayISO : null;
          filterEvents(); setTimeout(addDots, 200);
        },
        onMonthChange: function () { setTimeout(addDots, 100); },
        onYearChange:  function () { setTimeout(addDots, 100); },
        onChange: function (sd) {
          if (!sd.length) { applySmartDefault(); setTimeout(addDots, 100); return; }
          selectedDate = toISO(sd[0]); filterEvents(); setTimeout(addDots, 100);
        }
      });
    }
    function initCalendar(){
      if (typeof flatpickr === 'undefined') {
        var s = document.createElement('script');
        s.src = 'https://cdn.jsdelivr.net/npm/flatpickr';
        s.onload = setupFlatpickr;
        document.head.appendChild(s);
      } else { setupFlatpickr(); }
    }
    initCalendar();
  });
</script>
