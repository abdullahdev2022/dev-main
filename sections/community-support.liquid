{% schema %}
{
  "name": "Community & Giving",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Community & Giving"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Jewelry can do more than adorn — it can give back. We partner with nonprofits and community organizations."
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Card Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Fundraising Jewelry"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "Custom pieces designed to raise money for your non-profit cause"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button Label",
          "default": "Apply for support"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button Link"
        }
      ]
    }
  ],
  "max_blocks": 2,
  "presets": [
    {
      "name": "Community & Giving",
      "blocks": [{ "type": "card" }, { "type": "card" }]
    }
  ]
}
{% endschema %}
